{
  "rules": {
    "machines": {
      "$machineId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "sensors": {
          "sct013": {
            ".indexOn": ["timestamp"]
          },
          "thermistor": {
            ".indexOn": ["timestamp"]
          }
        },
        "commands": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "status": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    }
  }
}
